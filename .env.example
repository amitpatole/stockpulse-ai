```
# TickerPulse AI v3.0 - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values
# AI providers can also be configured via the Settings UI

# =====================
# Database Configuration
# =====================
# Supported backends: 'sqlite' (default, recommended for dev), 'postgres' (production)
DB_TYPE=sqlite

# SQLite configuration (used when DB_TYPE=sqlite):
# Can be absolute path or relative path from project root
DB_PATH=./stock_news.db

# PostgreSQL configuration (required only when DB_TYPE=postgres):
# Connection string format: postgresql://username:password@hostname:port/database_name
# Example: postgresql://tickerpulse:mypassword@localhost:5432/tickerpulse
# Notes:
#   - Port defaults to 5432 if not specified
#   - Database must exist and be accessible with the provided credentials
#   - This is IGNORED when DB_TYPE=sqlite (DB_PATH is used instead)
DATABASE_URL=postgresql://user:password@localhost:5432/tickerpulse

# PostgreSQL connection pool size (connections per app process)
# Only used when DB_TYPE=postgres (default: 10, range: 1-100)
DB_POOL_SIZE=10

# =====================
# AI Providers (optional - configure via UI or here)
# =====================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_KEY=
XAI_API_KEY=

# =====================
# OpenClaw (optional - for OpenClaw agent framework)
# =====================
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_WEBHOOK_TOKEN=
OPENCLAW_ENABLED=false

# =====================
# Data Providers (optional - install only what you use)
# yfinance is always available as free default (stocks)
# coingecko is always available as free default (crypto)
# =====================
POLYGON_API_KEY=
ALPHA_VANTAGE_KEY=
FINNHUB_API_KEY=
TWELVE_DATA_KEY=
COINGECKO_API_KEY=    # Optional: CoinGecko API key for premium features (free tier doesn't require)

# =====================
# Reddit (optional - for PRAW authenticated access)
# Reddit .json endpoints work without credentials
# =====================
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# =====================
# GitHub (for repository analytics)
# =====================
GITHUB_TOKEN=

# =====================
# Agent Framework
# =====================
DEFAULT_AGENT_FRAMEWORK=crewai    # 'crewai' or 'openclaw'

# =====================
# Cost Management
# =====================
MONTHLY_BUDGET_LIMIT=1500.0
DAILY_BUDGET_WARNING=75.0

# =====================
# App Configuration
# =====================
FLASK_PORT=5000
FLASK_DEBUG=false
NEXT_PUBLIC_API_URL=http://localhost:5000
MARKET_TIMEZONE=US/Eastern
CHECK_INTERVAL=300
LOG_LEVEL=INFO
SECRET_KEY=change-this-to-a-random-string-in-production
```