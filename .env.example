```bash
# ============================================================================
# TickerPulse AI v3.0 - Environment Configuration
# ============================================================================

# --- Flask Configuration ---
FLASK_PORT=5000
FLASK_DEBUG=false
SECRET_KEY=change-me-in-production

# --- Database Configuration (SQLite) ---
# Default: SQLite for development
DB_TYPE=sqlite
DB_PATH=./stock_news.db

# --- Database Configuration (PostgreSQL) ---
# To use PostgreSQL, set:
# DB_TYPE=postgres
# DATABASE_URL=postgresql://username:password@localhost:5432/tickerpulse
# DB_POOL_SIZE=10
#
# Example:
# DB_TYPE=postgres
# DATABASE_URL=postgresql://tickerpulse:password123@db.example.com:5432/tickerpulse_prod
# DB_POOL_SIZE=20

DATABASE_URL=postgresql://user:password@localhost:5432/tickerpulse
DB_POOL_SIZE=10

# --- CORS Configuration ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# --- Market Configuration ---
MARKET_TIMEZONE=US/Eastern

# --- Check Interval (seconds) ---
CHECK_INTERVAL=300

# --- API Keys (Keep these secret!) ---
# AlphaVantage
ALPHAVANTAGE_API_KEY=your_key_here

# NewsAPI
NEWSAPI_API_KEY=your_key_here

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_key_here

# OpenAI
OPENAI_API_KEY=your_key_here

# Groq
GROQ_API_KEY=your_key_here
```