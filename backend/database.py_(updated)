def init_all_tables():
    """Initialize all database tables (both existing and new v3.0 tables)."""
    if Config.DB_TYPE.lower() == "postgres":
        _init_postgres_tables()
    else:
        _init_sqlite_tables()


def _init_sqlite_tables():
    """Initialize SQLite tables."""
    conn = get_db_connection()
    cursor = conn.cursor()

    try:
        # Existing tables
        for sql in _EXISTING_TABLES_SQL:
            cursor.execute(sql)

        # New v3.0 tables
        for sql in _NEW_TABLES_SQL:
            cursor.execute(sql)

        # Indexes
        for sql in _NEW_INDEXES_SQL:
            cursor.execute(sql)

        conn.commit()
        logger.info("All SQLite tables initialized successfully")
    except Exception as e:
        logger.error(f"Error initializing tables: {e}")
        conn.rollback()
        raise
    finally:
        conn.close()


def _init_postgres_tables():
    """Initialize PostgreSQL tables."""
    adapter = get_adapter()

    try:
        with adapter.get_connection() as conn:
            cursor = conn.cursor()

            # Existing tables
            for sql in _EXISTING_TABLES_SQL_POSTGRES:
                cursor.execute(sql)

            # New v3.0 tables
            for sql in _NEW_TABLES_SQL_POSTGRES:
                cursor.execute(sql)

            # Indexes
            for sql in _NEW_INDEXES_SQL:
                cursor.execute(sql)

            conn.commit()
            logger.info("All PostgreSQL tables initialized successfully")
    except Exception as e:
        logger.error(f"Error initializing PostgreSQL tables: {e}")
        raise